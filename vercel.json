{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/blog",
      "destination": "/blog.html",
      "permanent": true
    },
    {
      "source": "/news",
      "destination": "/news.html",
      "permanent": true
    },
    {
      "source": "/products",
      "destination": "/products.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/fr",
      "destination": "/fr/index.html"
    },
    {
      "source": "/de",
      "destination": "/de/index.html"
    },
    {
      "source": "/es",
      "destination": "/es/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
